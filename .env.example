# ==========================================
# Database — Supabase + Prisma (Vercel)
# ==========================================
# Get both URLs from: Supabase → Settings → Database → Connection string
#
# DATABASE_URL  → Connection Pooler (Transaction mode, port 6543)
#   Used by the app at runtime via pgbouncer (required for Vercel serverless).
#   Format: postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#
# DIRECT_URL    → Direct connection (port 5432)
#   Used by Prisma migrations / prisma db push only.
#   Format: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
#
DATABASE_URL="postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# Next.js public vars (prefix with NEXT_PUBLIC_ to expose to browser)
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_NEXTAUTH_URL="http://localhost:3000"

# NextAuth Configuration
NEXTAUTH_SECRET="<generate-with: openssl rand -base64 32>"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (get from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

GEMINI_API_KEY="your-gemini-api-key"
OPENAI_API_KEY="your-openai-api-key"

# ==========================================
# Cloudinary Configuration (Image Storage)
# ==========================================
# Get from: https://cloudinary.com/console/settings
# 1. Login to Cloudinary
# 2. Go to Settings (gear icon) > API Keys
# 3. Copy Cloud Name, API Key, and API Secret

CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# ==========================================
# Redis Configuration (for Bull Queue)
# ==========================================
# --- Option A: Local / self-hosted Redis (development) ---
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD="your-redis-password"

# --- Option B: Upstash Redis (production / Vercel) ---
# Get from: https://console.upstash.com → your database → REST API tab
# When these are set they take priority over Option A.
# UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ==========================================
# EmailJS — transactional email
# ==========================================
# Dashboard: https://dashboard.emailjs.com
#
# HOW IT WORKS (two-step):
#   1. Server tries to send with private key (EMAILJS_PRIVATE_KEY).
#      Free plan / missing key → returns clientEmailNeeded flag.
#   2. Browser retries with public key (NEXT_PUBLIC_EMAILJS_PUBLIC_KEY).
#      Browser Origin header satisfies EmailJS allowed-origins check.
#
# EmailJS dashboard setup required:
#   - Account → Security → Allowed Origins → add your production domain
#   - Create an Email Service (SMTP or Gmail) → copy Service ID
#   - Create template with: {{to_email}} {{to_name}} {{verify_link}} {{site_name}}
#
# SERVER-SIDE (not exposed to browser)
EMAILJS_SERVICE_ID="service_xxxxxxx"
EMAILJS_TEMPLATE_ID="template_xxxxxxx"
EMAILJS_USER_ID="your_public_key"
EMAILJS_PRIVATE_KEY="your_private_key"

# CLIENT-SIDE (copy same values — safe to expose, Origin-validated by EmailJS)
NEXT_PUBLIC_EMAILJS_SERVICE_ID="service_xxxxxxx"
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID="template_xxxxxxx"
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY="your_public_key"

# Production URL (used to build verification links)
NEXT_PUBLIC_SITE_URL="https://seredityfy.art"
