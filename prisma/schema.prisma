generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("seredityfy_POSTGRES_URL_NON_POOLING")
}

enum ImageStatus {
  PENDING
  COMPLETED
  FAILED 
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum BillingCycle {
  WEEKLY
  MONTHLY
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum GenerationMode {
  HYBRID
  GEMINI_ONLY
  CHATGPT_ONLY
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  images        GeneratedImage[]
  videos        GeneratedVideo[]
  subscription  Subscription?
  promptHistory PromptHistory[]
}

model GeneratedImage {
  id        String   @id @default(cuid())
  prompt    String   @db.Text
  enhancedPrompt String? @db.Text
  imageUrl  String?
  thumbnailUrl String?
  status    ImageStatus @default(PENDING)
  userId    String?
  model     String   @default("seredityfy-v2")
  visibility Visibility @default(PUBLIC)
  generationMode GenerationMode @default(HYBRID)
  metadata  Json?
  width     Int?
  height    Int?
  seed      Int?
  steps     Int?
  guidanceScale Float?
  negativePrompt String?
  isApproved Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([visibility])
  @@index([createdAt])
}

model PromptEmbedding {
  id        String   @id @default(cuid())
  imageId   String   @unique
  embedding Json
  model     String   @default("text-embedding-3-small")
  createdAt DateTime @default(now())

  @@index([imageId])
}

model Subscription {
  id              String           @id @default(cuid())
  userId          String           @unique
  plan            SubscriptionPlan @default(FREE)
  billingCycle    BillingCycle     @default(WEEKLY)
  validUntil      DateTime?
  credits         Int              @default(40)
  usedCredits     Int              @default(0)
  monthlyCredits  Int?             @default(160)
  creditResetDate DateTime?
  canSharePublic  Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PromptHistory {
  id        String   @id @default(cuid())
  userId    String
  prompt    String   @db.Text
  enhancedPrompt String? @db.Text
  model     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum VideoStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum VideoEngine {
  VEO
  LUMA
  RUNWAY
  PIKA
}

model GeneratedVideo {
  id              String      @id @default(cuid())
  prompt          String      @db.Text
  enrichedPrompt  String?     @db.Text
  sourceImageUrl  String?
  sourceImageName String?
  videoUrl        String?
  thumbnailUrl    String?
  status          VideoStatus @default(PENDING)
  engine          VideoEngine @default(LUMA)
  duration        Float?      @default(8)
  motionStyle     String?
  cameraStyle     String?
  style           String?
  userId          String?
  aspectRatio     String?     @default("16:9")
  creditsCost     Int         @default(24)
  metadata        Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ImageReport {
  id        String   @id @default(cuid())
  imageId   String
  reporterId String
  reason    String   @db.Text
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  @@index([imageId])
  @@index([reporterId])
}
